generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ANNOTATOR
  REVIEWER
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum EvaluationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum IssueType {
  NONE
  HALLUCINATION
  UNSAFE
  IRRELEVANT
  INCOMPLETE
  BIAS
  OTHER
}

model User {
  id           String @id @default(uuid())
  name         String
  email        String @unique
  passwordHash String
  role         Role   @default(ANNOTATOR)

  createdProjects Project[]    @relation("ProjectCreator")
  assignedTasks   Task[]       @relation("TaskAssignee")
  evaluations     Evaluation[] @relation("EvaluationAnnotator")
  reviews         Evaluation[] @relation("EvaluationReviewer")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String        @id @default(uuid())
  title       String
  description String
  domain      String
  status      ProjectStatus @default(DRAFT)
  deadline    DateTime?

  createdById String
  createdBy   User   @relation("ProjectCreator", fields: [createdById], references: [id])

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
  @@index([status])
}

model Task {
  id         String     @id @default(uuid())
  prompt     String
  response   String
  category   String
  difficulty Difficulty @default(MEDIUM)
  status     TaskStatus @default(PENDING)
  dueDate    DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?   @relation("TaskAssignee", fields: [assignedToId], references: [id])

  evaluation Evaluation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([assignedToId])
  @@index([status])
}

model Evaluation {
  id String @id @default(uuid())

  accuracy  Int
  relevance Int
  coherence Int
  safety    Int

  overallScore Float

  issueType IssueType @default(NONE)
  notes     String

  status EvaluationStatus @default(DRAFT)

  taskId String @unique
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  annotatorId String
  annotator   User   @relation("EvaluationAnnotator", fields: [annotatorId], references: [id])

  reviewerId String?
  reviewer   User?   @relation("EvaluationReviewer", fields: [reviewerId], references: [id])

  reviewerFeedback String?
  reviewedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([annotatorId])
  @@index([reviewerId])
  @@index([status])
}
